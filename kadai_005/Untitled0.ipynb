        "number1 = 10\n",
        "# 下辺\n",
        "number2 = 20\n",
        "# 高さ\n",
        "number3 = 5\n",
        "\n",
        "# 公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "print(f\"台形の面積は{(number1 + number2) * (number3) / 2}cm²です。\")\n"
